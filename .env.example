# ==============================
# ILMAR STUDIO — Variables de entorno
# Copia este archivo como .env y completa los valores reales
# El archivo .env NUNCA se sube a git
# ==============================

# Puerto del servidor
PORT=3000

# Entorno: development | production
NODE_ENV=production

# Contraseña del panel admin — usa algo seguro, solo tú debes saberla
ADMIN_PASSWORD=pon-aqui-tu-contrasena-segura

# JWT Secret — genera uno con: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=genera-un-secreto-largo-y-aleatorio

# MongoDB Atlas — connection string (obligatorio)
# Crea tu cluster gratis en mongodb.com/atlas
# Formato: mongodb+srv://usuario:password@cluster.mongodb.net/ilmarstudio
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@CLUSTER.mongodb.net/ilmarstudio

# Stripe (opcional — dejar vacío si no usas pagos online)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# URL base del dominio en producción (sin barra final)
# Ejemplos: https://ilmarstudio.com | https://tu-app.railway.app
BASE_URL=http://localhost:3000
